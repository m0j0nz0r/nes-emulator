{
	"version": "2.0.0",
	"tasks": [
    {
      "label": "Watch Express Server",
      "type": "shell",
      "command": "node --watch --require ts-node/register --watch-path=. --watch-path=../path/to/local-module server.ts",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen" 
      }
    }
  ]
}