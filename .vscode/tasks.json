{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch Express Server",
      "type": "shell",
      "command": "node --watch --require ts-node/register --watch-path=. --watch-path=../path/to/local-module server.ts",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Build All NES ROMs",
      "type": "shell",
      "command": "make",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean All ROMs",
      "type": "shell",
      "command": "make clean"
    },
    {
      "label": "Build Specific ROM",
      "type": "shell",
      "command": "make build-${input:romName}"
    }
  ],
  "inputs": [
    {
      "id": "romName",
      "type": "promptString",
      "description": "Name of the ROM folder to build (e.g. rom1)"
    }
  ]
}