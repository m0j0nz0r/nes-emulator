{
  "author": "Victor Hernandez",
  "license": "MIT",
  "name": "nes-emulator",
  "version": "1.0.0",
  "description": "A Nintendo Entertainment System (NES) emulator written in TypeScript.",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "watch": {
    "build": {
      "patterns": ["src/**/*.ts"],
      "extensions": "ts",
      "ignore": "node_modules"
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/nanotimer": "^0.3.2",
    "@types/node": "20.8.2",
    "gts": "^5.2.0",
    "jest": "^29.7.0",
    "npm-watch": "^0.13.0",
    "ts-jest": "^29.2.6",
    "typescript": "~5.2.0"
  },
  "scripts": {
    "build": "tsc",
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "watch": "npm-watch build",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m0j0nz0r/nes-emulator.git"
  },
  "keywords": [
    "nes",
    "emulator",
    "typescript"
  ],
  "dependencies": {
    "nanotimer": "^0.3.15"
  }
}
